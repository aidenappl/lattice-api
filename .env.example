# Required
DATABASE_DSN=root:lattice@tcp(localhost:3306)
JWT_SIGNING_KEY=change-me-to-a-random-secret

# Bootstrap admin (creates initial local admin if no users exist)
LATTICE_ADMIN_EMAIL=admin@lattice.local
LATTICE_ADMIN_PASSWORD=changeme

# Server
PORT=8000
ENVIRONMENT=development

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://lattice.local.appleby.cloud:3000

# Cookie domain (required when frontend and API are on different subdomains)
# COOKIE_DOMAIN=.appleby.cloud

# Forta OAuth2 (optional — only needed when Forta is running)
# FORTA_API_DOMAIN=https://forta-api.appleby.cloud
# FORTA_LOGIN_DOMAIN=https://login.appleby.cloud
# FORTA_APP_DOMAIN=https://lattice.appleby.cloud
# FORTA_CLIENT_ID=
# FORTA_CLIENT_SECRET=
# FORTA_CALLBACK_URL=https://lattice-api.appleby.cloud/forta/callback
# FORTA_JWT_SIGNING_KEY=
# FORTA_COOKIE_DOMAIN=.appleby.cloud
# FORTA_COOKIE_INSECURE=false
# FORTA_POST_LOGIN_REDIRECT=/
# FORTA_POST_LOGOUT_REDIRECT=/
# FORTA_FETCH_USER_ON_PROTECT=true
# FORTA_DISABLE_AUTO_REFRESH=false
# FORTA_ENFORCE_GRANTS=true
