# Required
DATABASE_DSN=root:lattice@tcp(localhost:3306)
JWT_SIGNING_KEY=change-me-to-a-random-secret

# Bootstrap admin (creates initial local admin if no users exist)
LATTICE_ADMIN_EMAIL=admin@lattice.local
LATTICE_ADMIN_PASSWORD=changeme

# Server
PORT=8000
ENVIRONMENT=development

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://lattice.local.appleby.cloud:3000

# Cookie domain (required when frontend and API are on different subdomains)
# COOKIE_DOMAIN=.appleby.cloud

# SSO OAuth2 (optional — enables "Sign in with SSO" on the login page)
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_AUTHORIZE_URL=https://auth.example.com/oauth/authorize
# SSO_TOKEN_URL=https://auth.example.com/oauth/token
# SSO_USERINFO_URL=https://auth.example.com/oauth/userinfo
# SSO_REDIRECT_URL=https://lattice-api.example.com/auth/sso/callback
# SSO_LOGOUT_URL=https://auth.example.com/oauth/logout
# SSO_SCOPES=openid email profile
# SSO_USER_IDENTIFIER=email
# SSO_BUTTON_LABEL=Sign in with SSO
# SSO_AUTO_PROVISION=true
